# Anthropic API key — powers the AI interview (lib/interview.ts) and the
# feasibility report composer (lib/report.ts). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: model override. Defaults to a current Claude Sonnet in lib/anthropic.ts.
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: Socrata app token raises PLUTO API rate limits. Not required for v1.
# SOCRATA_APP_TOKEN=
